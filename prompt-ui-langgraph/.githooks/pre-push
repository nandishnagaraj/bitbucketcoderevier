#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(git rev-parse --show-toplevel)"
HOOK_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

if [[ -f "$HOOK_DIR/../scripts/run_pre_push_review.sh" ]]; then
	"$HOOK_DIR/../scripts/run_pre_push_review.sh"
elif [[ -f "$ROOT_DIR/prompt-ui-langgraph/scripts/run_pre_push_review.sh" ]]; then
	"$ROOT_DIR/prompt-ui-langgraph/scripts/run_pre_push_review.sh"
elif [[ -f "$ROOT_DIR/scripts/run_pre_push_review.sh" ]]; then
	"$ROOT_DIR/scripts/run_pre_push_review.sh"
else
	echo "[pre-push] Could not find scripts/run_pre_push_review.sh"
	exit 1
fi
